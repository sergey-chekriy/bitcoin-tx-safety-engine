{
  "name": "bitcoin-tx-safety-engine",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source Bitcoin transaction safety analysis engine and CLI",
  "license": "MIT",
  "author": "Sergey Chekriy",
  "repository": {
    "type": "git",
    "url": "https://github.com/sergey-chekriy/bitcoin-tx-safety-engine.git"
  },
  "homepage": "https://github.com/sergey-chekriy/bitcoin-tx-safety-engine",
  "bugs": {
    "url": "https://github.com/sergey-chekriy/bitcoin-tx-safety-engine/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "btse": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/cli/index.ts --help",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "ci": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
